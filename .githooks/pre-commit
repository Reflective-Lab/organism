#!/usr/bin/env bash
set -euo pipefail

echo "──────────────────────────────────────────────"
echo "Pre-commit hook: Running lint..."
echo "──────────────────────────────────────────────"

# Ensure just is installed
if ! command -v just &> /dev/null; then
    echo "Error: 'just' is not installed. Please install it to run pre-commit hooks."
    exit 1
fi

# Run just lint
just lint

echo "──────────────────────────────────────────────"
echo "✓ Pre-commit checks passed"
echo "──────────────────────────────────────────────"
