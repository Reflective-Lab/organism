#!/usr/bin/env bash
set -euo pipefail

echo "pre-commit: checking formatting..."
if ! cargo fmt --check 2>/dev/null; then
    echo ""
    echo "Formatting errors found. Run 'cargo fmt' and re-commit."
    exit 1
fi

echo "pre-commit: running clippy..."
if ! cargo clippy --workspace --all-targets -- -D warnings 2>/dev/null; then
    echo ""
    echo "Clippy warnings found. Fix them and re-commit."
    exit 1
fi

echo "pre-commit: ok"
