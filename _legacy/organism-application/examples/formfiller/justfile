# Formfiller development commands

# Default: show available commands
default:
    @just --list

# === Build & Run ===

# Build the formfiller binary
build:
    cargo build

# Build release binary
build-release:
    cargo build --release

# Run the TUI (default mode)
run:
    cargo run

# Run with a specific command
run-cmd *ARGS:
    cargo run -- {{ARGS}}

# === Test Cluster ===

# Start the test cluster (forms server + logger)
up:
    cd test-forms && docker compose up -d

# Stop the test cluster
down:
    cd test-forms && docker compose down

# Restart the test cluster
restart:
    cd test-forms && docker compose restart

# Show test cluster status
status:
    cd test-forms && docker compose ps

# Show test cluster logs
logs:
    cd test-forms && docker compose logs -f

# Show logs for forms server only
logs-forms:
    cd test-forms && docker compose logs -f forms

# Show logs for logger server only
logs-logger:
    cd test-forms && docker compose logs -f logger

# === WebDriver ===

# Start ChromeDriver (requires chromedriver installed)
chromedriver:
    chromedriver --port=9515

# Start ChromeDriver in background
chromedriver-bg:
    chromedriver --port=9515 &

# === Tasks ===

# List all tasks
tasks:
    cargo run -- tasks

# Show task queue summary with priority beads
tasks-summary:
    cargo run -- tasks summary

# Show next task to run
tasks-next:
    cargo run -- tasks next

# Add a task (usage: just task-add "name" "form" [priority])
task-add NAME FORM PRIORITY="normal":
    cargo run -- tasks add "{{NAME}}" --form "{{FORM}}" --priority {{PRIORITY}}

# Run the next task in queue
task-run:
    cargo run -- tasks run

# === Forms ===

# List all form configs
forms:
    cargo run -- list

# Analyze a URL and discover form fields
analyze URL:
    cargo run -- analyze "{{URL}}"

# Fill a form (usage: just fill "form-name" [profile])
fill FORM PROFILE="":
    @if [ -z "{{PROFILE}}" ]; then \
        cargo run -- fill "{{FORM}}"; \
    else \
        cargo run -- fill "{{FORM}}" --profile "{{PROFILE}}"; \
    fi

# === Profiles ===

# List all profiles
profiles:
    cargo run -- profiles

# === Learning ===

# Learn from logging server and update form configs
learn:
    cargo run -- learn

# Show validation errors from logs
errors:
    cargo run -- errors

# === Development ===

# Run tests
test:
    cargo test

# Check code without building
check:
    cargo check

# Format code
fmt:
    cargo fmt

# Lint code
lint:
    cargo clippy

# Clean build artifacts
clean:
    cargo clean

# === Quick Start ===

# Start everything needed for development
dev: up chromedriver-bg
    @echo "Test cluster started on http://localhost:8080"
    @echo "Logger API on http://localhost:3001"
    @echo "ChromeDriver on http://localhost:9515"
    @echo ""
    @echo "Run 'just run' to start the TUI"
